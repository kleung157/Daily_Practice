library(tidyverse)
library(stringi)

result_df <- violations_df |>
    distinct(
        # 1. Find single instance of business names
        business_name
    ) |>
    mutate(
        # 2. Convert accented characters to base form
        clean_name = stri_trans_general(business_name, "Latin-ASCII") |> str_to_lower(),

        # 3. Classify business name based on classification criteria using text search
        business_type = case_when(
            str_detect(clean_name, regex("restaurant", ignore_case=TRUE)) ~ "restaurant",
            str_detect(clean_name, regex("cafe|coffee", ignore_case=TRUE)) ~ "cafe",
            str_detect(clean_name, regex("school", ignore_case=TRUE)) ~ "school",
            TRUE ~ "other"
        )
    ) |>
    select(
        # 4. Select relevant columns
        business_name, business_type
    )
    arrange(
        # 5. Sort in ascending order by business_type and business_name
        business_type, business_name
    )

