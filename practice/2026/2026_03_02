## Iteration:
# 1. Filter for players that were drafted into NFL
#    != 0 and != NULL in pickround column 
# 2. Count the number of players for each college
# 3. Sort in descending order by player_count

## Result:
result_df = (
    combine_df
    .loc[lambda x:
        # 1. Filter for players that were drafted into NFL
        #    != 0 and != NULL in pickround column 
        x["college"].notna() &
        x["pickround"] != 0 &
        x["pickround"].notna()
    ]
    # 2. Count the number of players for each college
    .groupby("college")
    .size()
    .reset_index(name="player_count")
    # 3. Sort in descending order by player_count
    .sort_values(by="player_count", ascending=False)
)

print("Colleges that produce the most NFL players: ")
result_df

