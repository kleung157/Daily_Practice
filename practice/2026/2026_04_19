#        print("")

# multiple repeated values for user 1 and user 2 columns

## Iteration:
# 1. Count the number of interactions for each day
# 2. Count the number of distinct people involved for each day
# 3. Sort in ascending order by date and in descending order by number of people

## Result:
result_df = (
    interactions_df
    .groupby("day")
    .apply(
        lambda x: pd.Series(
            {
            # 1. Count the number of interactions for each day
            "num_interactions": len(x),
            # 2. Count the number of distinct people involved for each day
            "num_people": pd.unique(x[["user1", "user2"]].values.ravel()).size
            }
        )
    )
    .reset_index()
    # 3. Sort in ascending order by date and in descending order by number of people
    .sort_values(by=["day", "num_people"], ascending=[True, False])
)

