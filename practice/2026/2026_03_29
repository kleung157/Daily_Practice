def get_most_common_reaction(df, day):
    """
    Returns the most common reaction(s) for a specific day.
    """
    # 1. Logic remains the same, but we parameterize 'day'
    result = (
        df.loc[lambda x: x["date_day"] == day]
        .groupby("reaction")
        .size()
        .reset_index(name="num_occurrences")
    )
    
    # 2. Check if the result is empty (in case the day doesn't exist)
    if result.empty:
        return f"No data found for day {day}."
    
    # 3. Filter for the maximum occurrences
    return (
        result.loc[lambda x: x["num_occurrences"] == x["num_occurrences"].max()]
        .sort_values(by="reaction")
    )

# How to use it:
