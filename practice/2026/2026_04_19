## Output:
# day, num_interactions, num_people

## Import libraries:
import pandas as pd

## Load and preview data:
#facebook_user_interactions = pd.read_csv("facebook_user_interactions.csv")
interactions_df = facebook_user_interactions.copy()
interactions_df.head(5)

## Data quality:
# Dimensions - 10 x 3
