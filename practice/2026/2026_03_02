** Solution #2 ** (revised with suggestions)
result_df <- inspections_df |> 
    mutate(
        # 1. Extract the month number from the date
        month = month(activity_date, label=TRUE, abbr=FALSE)
    ) |>
    count(
        # 2. Count the number of inspections per month across all years
        month, name="num_inspections"
    ) |>
    slice_min(
        # 3. Filter for month with lowest number of inspections
        num_inspections, with_ties=TRUE
    )

