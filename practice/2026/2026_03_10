** Solution #1 ** (original attempt)
-- Question:
-- Identify the top 3 posts with the highest like counts for each channel.
-- Assign a rank to each post based on its like count,
-- allowing for gaps in ranking when posts have the same number of likes.
-- For example, if two posts tie for 1st place,
-- the next post should be ranked 3rd, not 2nd. 
-- Exclude any posts with zero likes.
-- The output should display the channel name, post ID, post creation date, 
-- and the like count for each post.
-- Because there could be ties in ranking,
-- your output could have more than 3 rows for each channel.

-- Input:
-- posts, channels

-- Output:
-- channel_name, post_id, post_creation_date, like_count

-- Preview data:
SELECT TOP 5* FROM posts;
SELECT TOP 5* FROM channels;

-- Data quality:
-- Dimensions - posts: 51 x 6
--            - channels: 5 x 3
-- Duplicates - posts: 0
--            - channels: 0
-- Nulls - posts: 0
--         channels: 0
-- Value Counts - posts: channel_id, post_id
--                channels: channel_id, channel_name, channel_type
SELECT -- Dimensions and nulls
    SUM(CASE WHEN channel_id IS NULL THEN 1 ELSE 0 END) AS col1,
    SUM(CASE WHEN comments IS NULL THEN 1 ELSE 0 END) AS col2,
    SUM(CASE WHEN created_at IS NULL THEN 1 ELSE 0 END) AS col3,
    SUM(CASE WHEN likes IS NULL THEN 1 ELSE 0 END) AS col4,
    SUM(CASE WHEN post_id IS NULL THEN 1 ELSE 0 END) AS col5,
    SUM(CASE WHEN shares IS NULL THEN 1 ELSE 0 END) AS col6,
    COUNT(*) AS row_count
FROM posts;

SELECT -- Dimensions and nulls
    SUM(CASE WHEN channel_id IS NULL THEN 1 ELSE 0 END) AS col1,
    SUM(CASE WHEN channel_name IS NULL THEN 1 ELSE 0 END) AS col2,
    SUM(CASE WHEN channel_type IS NULL THEN 1 ELSE 0 END) AS col3,
    COUNT(*) AS row_count
FROM channels;

SELECT -- Duplicates
    channel_id, comments, created_at, likes, post_id, shares,
    COUNT(*)
FROM posts
GROUP BY
    channel_id, comments, created_at, likes, post_id, shares
HAVING COUNT(*) > 1;

SELECT -- Duplicates
    channel_id, channel_name, channel_type,
    COUNT(*)
FROM channels
GROUP BY
    channel_id, channel_name, channel_type
HAVING COUNT(*) > 1;

SELECT -- Value Counts, multiple repeated values
    channel_id, 
    COUNT(*) AS frequency
FROM posts
GROUP BY channel_id
ORDER BY frequency DESC;

SELECT -- Value Counts, all unique values
    post_id, 
    COUNT(*) AS frequency
FROM posts
GROUP BY post_id
ORDER BY frequency DESC;

SELECT -- Value Counts, all unique values
    channel_id, 
    COUNT(*) AS frequency
FROM channels
GROUP BY channel_id
ORDER BY frequency DESC;

SELECT -- Value Counts, all unique values
    channel_name, 
    COUNT(*) AS frequency
FROM channels
GROUP BY channel_name
ORDER BY frequency DESC;

SELECT -- Value Counts, multiple repeated values
    channel_type, 
    COUNT(*) AS frequency
FROM channels
GROUP BY channel_type
ORDER BY frequency DESC;

-- Iteration:
-- 1. Join posts and channels tables by channel_id
-- 2. Filter for posts with non zero or non null likes
-- 3. Calculate the total number of likes for each post based on channel 
-- 4. Rank posts by number of likes in descending order for each channel, allow gaps for ties
-- 5. Filter for top 3 posts with highest like counts based on rank

-- Result:
WITH RankedChannels AS (
    SELECT 
        c.channel_name,
        p.created_at AS post_creation_date,
        p.post_id,
        -- 3. Calculate the total number of likes for each post based on channel 
        SUM(p.likes) AS total_likes,
        -- 4. Rank posts by number of likes in descending order for each channel, allow gaps for ties
        RANK() OVER(
            PARTITION BY c.channel_name 
            ORDER BY SUM(p.likes) DESC
        ) AS like_rank 
    FROM 
        posts AS p
    LEFT JOIN 
        -- 1. Join posts and channels tables by channel_id
        channels AS c
        ON p.channel_id = c.channel_id
    WHERE
        -- 2. Filter for posts with non zero or non null likes
        p.likes IS NOT NULL 
        AND p.likes > 0
    GROUP BY
        c.channel_name,
        p.created_at,
        p.post_id
)
SELECT
    channel_name,
    post_id,
    post_creation_date,
    total_likes
FROM 
    RankedChannels
WHERE
    -- 5. Filter for top 3 posts with highest like counts based on rank
    like_rank <= 3
ORDER BY
    channel_name ASC,
    like_rank ASC;

-------------------------------------------------------------------------------
